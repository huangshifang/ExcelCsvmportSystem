# ============================================
# Excel Import System — Docker 环境变量
# 复制此文件为 .env 后按需修改
# ============================================

# SQL Server SA 密码 (至少 8 位，含大小写字母+数字+符号)
SA_PASSWORD=YourStrong!Passw0rd

# JWT 签名密钥 (至少 32 字符，生产环境请更换为随机字符串)
JWT_KEY=YourSuperSecretKeyAtLeast32CharactersLong!

# LDAP/AD 认证 (默认关闭)
LDAP_ENABLED=false
